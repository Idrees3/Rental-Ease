NEXT_PUBLIC_SUPABASE_URL=https://efwcyuhtknalmsnrshka.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias (same value as publishable key):
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_PROJECT_REF=efwcyuhtknalmsnrshka
# Optional — only for CLI / direct DB access (never commit real password):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.efwcyuhtknalmsnrshka.supabase.co:5432/postgres

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Rental Ease <reminders@rentalease.app>

# OneSignal — https://dashboard.onesignal.com
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Optional: daily automatic reminders (Vercel cron)
# CRON_SECRET=your_random_secret
# SUPABASE_SERVICE_ROLE_KEY=from Supabase Settings → API → service_role

# App URL (email links, push, auth redirects)
# Local: http://localhost:3000
# Production: https://rentalease.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
